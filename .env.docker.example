# Django Core
DJANGO_SETTINGS_MODULE=config.settings.docker
SECRET_KEY=your-secret-key-here-change-this
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1,django,frontend,db,redis

# Database (PostgreSQL in Docker)
POSTGRES_USER=fooddelivery_user
POSTGRES_PASSWORD=your-postgres-password-here
POSTGRES_DB=food_delivery_dev
DB_HOST=db
DB_PORT=5432
DB_CONN_MAX_AGE=600

# Cache (Redis in Docker)
REDIS_URL=redis://redis:6379/0
REDIS_CHANNEL_HOST=redis
REDIS_CHANNEL_PORT=6379

# Celery
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# Email
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password-here
DEFAULT_FROM_EMAIL=noreply@yourdomain.com

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000,http://frontend:3000,http://django:8000
CSRF_TRUSTED_ORIGINS=http://localhost:3000,http://localhost:8000,http://frontend:3000

# Session & Security
SESSION_COOKIE_SECURE=False
CSRF_COOKIE_SECURE=False

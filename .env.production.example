# Django Core
DJANGO_SETTINGS_MODULE=config.settings.production
SECRET_KEY=your-production-secret-key-here-change-this
DEBUG=False
ALLOWED_HOSTS=yourdomain.com,www.yourdomain.com,api.yourdomain.com

# Database (PostgreSQL - Production)
DB_NAME=food_delivery_prod
DB_USER=prod_user
DB_PASSWORD=your-postgres-password-here
DB_HOST=prod-db.example.com
DB_PORT=5432
DB_CONN_MAX_AGE=600

# Cache (Redis - Production)
REDIS_URL=redis://prod-redis.example.com:6379/0
REDIS_CHANNEL_HOST=prod-redis.example.com
REDIS_CHANNEL_PORT=6379

# Celery
CELERY_BROKER_URL=redis://prod-redis.example.com:6379/1
CELERY_RESULT_BACKEND=redis://prod-redis.example.com:6379/2

# Email
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-production-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password-here
DEFAULT_FROM_EMAIL=noreply@yourdomain.com

# CORS
CORS_ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com,https://api.yourdomain.com
CSRF_TRUSTED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# Session & Security
SESSION_COOKIE_SECURE=True
CSRF_COOKIE_SECURE=True
SESSION_COOKIE_HTTPONLY=True

# Additional Security
SECURE_SSL_REDIRECT=True
SECURE_HSTS_SECONDS=31536000
SECURE_HSTS_INCLUDE_SUBDOMAINS=True
SECURE_HSTS_PRELOAD=True
SECURE_BROWSER_XSS_FILTER=True
X_FRAME_OPTIONS=DENY
